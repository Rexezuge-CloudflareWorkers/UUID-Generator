{
  "name": "uuid-generator-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "clean": "rm -rf dist/",
    "prebuild": "npm run prettier && npm run lint",
    "build": "tsc -b && vite build",
    "prerelease": "pnpm run clean && pnpm install",
    "release": "pnpm run build",
    "prettier": "prettier --write .",
    "lint": "eslint --ext .ts,.tsx --fix .",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.x",
    "@eslint/js": "^10.0.x",
    "@tailwindcss/vite": "^4.3.x",
    "@types/node": "^26.1.x",
    "@types/react": "^19.1.x",
    "@types/react-dom": "^19.1.x",
    "@vitejs/plugin-react": "^6.0.x",
    "eslint": "^10.7.x",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.1.x",
    "eslint-plugin-react-refresh": "^0.5.x",
    "globals": "^17.7.x",
    "prettier": "^3.9.4",
    "typescript": "^6.0.x",
    "typescript-eslint": "^8.36.x",
    "vite": "^8.1.x"
  },
  "dependencies": {
    "react": "^19.1.x",
    "react-dom": "^19.1.x"
  },
  "type": "module"
}
