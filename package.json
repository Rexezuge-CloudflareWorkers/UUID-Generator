{
  "name": "uuid-generator",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "predeploy": "pnpm run buildApp && pnpm run cf-typegen",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "buildApp": "cd app && pnpm install && pnpm run release",
    "cf-typegen": "wrangler types",
    "checks": "pnpm -r typecheck && pnpm --filter uuid-generator-app lint && pnpm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist/",
    "prepare-wrangler-config": "pnpm exec tsx scripts/prepare-wrangler-config.ts",
    "prettier": "prettier --write .",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "prettier": "^3.8.x",
    "tsx": "^4.22.x",
    "typescript": "^6.0.x",
    "vitest": "^4.1.x",
    "wrangler": "^4.99.x"
  },
  "dependencies": {
    "chanfana": "^3.3.x",
    "hono": "^4.12.x",
    "zod": "^4.4.x"
  }
}
